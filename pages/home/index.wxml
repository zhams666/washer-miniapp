<view class="page">
  <Navbar showBackIcon="{{false}}" title="自助洗车" borderBottom="{{false}}" bottomShadow="{{true}}"></Navbar>

  <view class="container">
    <view class="banner-card">
      <view class="banner-content">
        <view class="banner-tag">门店精选</view>
        <view class="banner-title">{{storeInfo.name}}</view>
        <view class="banner-desc">{{storeInfo.desc}}</view>
        <view class="banner-notice">{{storeInfo.notice}}</view>
      </view>
      <image class="banner-image" mode="aspectFit" src="/assets/images/car.png"></image>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">快捷洗车</view>
        <view class="section-subtitle">到店后可直接开始操作</view>
      </view>
      <view class="feature-list">
        <view
          wx:for="{{featureCards}}"
          wx:key="key"
          class="feature-card"
          data-key="{{item.key}}"
          bindtap="handleFeatureTap"
        >
          <view class="feature-card__badge">{{item.badge}}</view>
          <view class="feature-card__icon">
            <Icon url="{{item.icon}}" size="52rpx"></Icon>
          </view>
          <view class="feature-card__title">{{item.title}}</view>
          <view class="feature-card__desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">常用服务</view>
        <view class="section-subtitle">门店服务、订单和账户管理</view>
      </view>
      <view class="quick-grid">
        <view
          wx:for="{{quickActions}}"
          wx:key="key"
          class="quick-card"
          data-key="{{item.key}}"
          bindtap="handleQuickAction"
        >
          <view class="quick-card__icon">
            <Icon url="{{item.icon}}" size="46rpx"></Icon>
          </view>
          <view class="quick-card__title">{{item.title}}</view>
          <view class="quick-card__desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
