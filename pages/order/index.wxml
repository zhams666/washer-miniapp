<view class="page">
  <Navbar showBackIcon="{{false}}" title="订单" borderBottom="{{false}}" bottomShadow="{{true}}"></Navbar>

  <view class="container">
    <view class="summary-card">
      <view class="summary-card__title">我的洗车订单</view>
      <view class="summary-card__desc">当前先接入最小订单闭环：创建测试订单并展示真实订单列表</view>
      <view class="summary-card__action" bindtap="createTestOrder">创建测试订单</view>
    </view>

    <view class="order-list" wx:if="{{list.length > 0}}">
      <view class="order-card" wx:for="{{list}}" wx:key="id">
        <view class="order-card__header">
          <view class="order-card__name">{{item.storeName}}</view>
          <view class="order-card__status status-{{item.statusType}}">{{item.status}}</view>
        </view>
        <view class="order-card__meta">下单时间 {{item.createTime}}</view>
        <view class="order-card__amount">实付金额 ￥{{item.amount}}</view>
        <view class="order-card__action" bindtap="showOrderDetail">查看详情</view>
      </view>
    </view>

    <view class="empty-card" wx:else>
      <image class="empty-card__image" mode="widthFix" src="/assets/images/no-order.png"></image>
      <view class="empty-card__title">暂无订单</view>
      <view class="empty-card__desc">点击上方按钮可创建一笔最小测试订单</view>
    </view>
  </view>
</view>
