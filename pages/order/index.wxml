<view class="page">
  <Navbar showBackIcon="{{false}}" title="Order" borderBottom="{{false}}" bottomShadow="{{true}}"></Navbar>

  <view class="container">
    <view class="summary-card">
      <view class="summary-card__title">My Wash Orders</view>
      <view class="summary-card__desc">
        Minimal order flow: create order, start order, complete order, and view real status changes.
      </view>
      <view class="summary-card__action" bindtap="createTestOrder">Create Test Order</view>
    </view>

    <view class="order-list" wx:if="{{list.length > 0}}">
      <view class="order-card" wx:for="{{list}}" wx:key="id">
        <view class="order-card__header">
          <view class="order-card__name">{{item.storeName}}</view>
          <view class="order-card__status status-{{item.statusType}}">{{item.status}}</view>
        </view>
        <view class="order-card__meta">Create Time {{item.createTime}}</view>
        <view class="order-card__amount">Amount ￥{{item.amount}}</view>
        <view
          class="order-card__action"
          data-id="{{item.id}}"
          data-action="{{item.actionType}}"
          bindtap="handleOrderAction"
        >
          {{item.actionText}}
        </view>
      </view>
    </view>

    <view class="empty-card" wx:else>
      <image class="empty-card__image" mode="widthFix" src="/assets/images/no-order.png"></image>
      <view class="empty-card__title">No Orders</view>
      <view class="empty-card__desc">Tap the button above to create a minimal test order.</view>
    </view>
  </view>
</view>
