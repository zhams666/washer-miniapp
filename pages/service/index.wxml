<view class="page">
  <Navbar showBackIcon="{{false}}" title="门店导航" borderBottom="{{false}}" bottomShadow="{{true}}"></Navbar>

  <view class="container">
    <view class="top-card">
      <view class="top-card__title">附近可用门店</view>
      <view class="top-card__desc">选择就近门店，支持到店自助洗车与导航到店</view>
    </view>

    <view class="store-list">
      <view class="store-card" wx:for="{{stores}}" wx:key="id">
        <image class="store-card__image" mode="aspectFill" src="{{item.image}}"></image>
        <view class="store-card__body">
          <view class="store-card__header">
            <view class="store-card__name">{{item.name}}</view>
            <view class="store-card__status status-{{item.statusType}}">{{item.status}}</view>
          </view>
          <view class="store-card__meta">距离 {{item.distance}}</view>
          <view class="store-card__meta">营业时间 {{item.businessHours}}</view>
          <view class="store-card__desc">{{item.desc}}</view>
          <view class="store-card__footer">
            <view class="store-card__notice">{{item.notice}}</view>
            <view
              class="store-card__button"
              data-name="{{item.name}}"
              bindtap="navigateStore"
            >
              导航
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
