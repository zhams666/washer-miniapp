<view class="page">
  <Navbar title="Wash Service" borderBottom="{{false}}" bottomShadow="{{true}}"></Navbar>

  <view class="container">
    <view class="summary-card">
      <view class="summary-card__tag">In service</view>
      <view class="summary-card__title">{{storeName}}</view>
      <view class="summary-card__desc">
        Device linked successfully. This page is currently a front-end demo for the minimal wash flow.
      </view>
    </view>

    <view class="status-card">
      <view class="status-card__icon-wrap">
        <Icon url="/assets/icons/car.png" size="56rpx"></Icon>
      </view>
      <view class="status-card__text">{{statusText}}</view>
      <view class="status-card__desc">The timer and fee are updated locally for now.</view>
    </view>

    <view class="data-card">
      <view class="data-card__row">
        <view class="data-card__label">Device No.</view>
        <view class="data-card__value">{{deviceNo}}</view>
      </view>
      <view class="data-card__row">
        <view class="data-card__label">Store</view>
        <view class="data-card__value">{{storeName}}</view>
      </view>
      <view class="data-card__row">
        <view class="data-card__label">Start Time</view>
        <view class="data-card__value">{{startTime}}</view>
      </view>
    </view>

    <view class="stats-grid">
      <view class="stats-card">
        <view class="stats-card__label">Elapsed</view>
        <view class="stats-card__value">{{timeLabel}}</view>
      </view>
      <view class="stats-card">
        <view class="stats-card__label">Current Fee</view>
        <view class="stats-card__value stats-card__value--fee">￥{{fee}}</view>
      </view>
    </view>

    <view class="tips-card">{{unitPriceText}}</view>

    <view class="action-row">
      <view class="action-btn action-btn--secondary" bindtap="togglePause">
        {{isPaused ? 'Resume' : 'Pause'}}
      </view>
      <view class="action-btn action-btn--primary" bindtap="endWash">Finish</view>
    </view>
  </view>
</view>
