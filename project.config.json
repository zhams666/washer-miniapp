{
  "projectname": "@wingscloud/template-wash",
  "description": "基于微信小程序 + TypeScript 的自助洗车开发模板。提供洗车流程、订单、钱包等 16 张页面模板。",
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "admin-web"
      },
      {
        "type": "folder",
        "value": "backend"
      },
      {
        "type": "folder",
        "value": "sql"
      }
    ],
    "include": []
  },
  "miniprogramRoot": "",
  "setting": {
    "useCompilerPlugins": [
      "typescript",
      "sass"
    ],
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    },
    "packNpmManually": true,
    "packNpmRelationList": [
      {
        "packageJsonPath": "./package.json",
        "miniprogramNpmDistDir": "./"
      }
    ],
    "es6": false,
    "enhance": false,
    "minifyWXSS": false,
    "postcss": false,
    "compileWorklet": false,
    "minified": false,
    "uglifyFileName": false,
    "uploadWithSourceMap": true,
    "minifyWXML": true,
    "localPlugins": false,
    "disableUseStrict": false,
    "condition": false,
    "swc": false,
    "disableSWC": true
  },
  "style": "v2",
  "simulatorType": "wechat",
  "simulatorPluginLibVersion": {},
  "condition": {},
  "srcMiniprogramRoot": "",
  "appid": "wx84913000e5469201",
  "libVersion": "2.26.1",
  "editorSetting": {
    "tabIndent": "insertSpaces",
    "tabSize": 2
  },
  "compileType": "miniprogram"
}
